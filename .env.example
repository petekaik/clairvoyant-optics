# Ympäristömuuttujat — kopioi tämä .env:ksi ja täytä arvot
# Tätä tiedostoa EI koskaan committata git:iin (.gitignore estää)

# === Video Streams (MediaMTX HLS) ===
# Resoluutiot: High 1920×1080, Medium 1024×576, Low 640×360
# HLS streamit MediaMTX-palvelimen kautta (192.168.1.20:8888)

# Etupiha (CAM1)
CAM1_STREAM=http://192.168.1.20:8888/etupiha/index.m3u8
CAM1_SNAP=https://192.168.1.X/snap.jpeg
CAM1_NAME=etupiha

# Takapiha (CAM2)
CAM2_STREAM=http://192.168.1.20:8888/takapiha/index.m3u8
CAM2_SNAP=https://192.168.1.X/snap.jpeg
CAM2_NAME=takapiha

# === MQTT (Home Assistant) ===
MQTT_BROKER=192.168.1.X
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=clairvoyant

# === ML-mallit ===
MODELS_DIR=./models
# Henkilötunnistus (YOLOv8)
YOLO_MODEL=yolov8n.onnx
# Kasvojentunnistus (InsightFace)
FACE_DETECTION_MODEL=det_10g.onnx
FACE_RECOGNITION_MODEL=w600k_r50.onnx

# === Tunnistuksen asetukset ===
PERSON_DETECT_CONFIDENCE=0.5
FACE_DETECT_CONFIDENCE=0.7
FACE_RECOGNITION_THRESHOLD=0.6
FRAME_INTERVAL=5

# === Logitus ===
LOG_LEVEL=INFO

# === macOS Integration ===
# PHOTOS_LIBRARY_PATH=              # Oletus: ~/Pictures/Photos Library.photoslibrary
# NOTIFICATION_SOUND_FAMILY=default  # macOS-ääni perheenjäsenelle
# NOTIFICATION_SOUND_ALERT=alarm     # macOS-ääni vieraalle
# NOTIFICATION_DND_START=            # Do Not Disturb alku (HH:MM), ei pakollinen
# NOTIFICATION_DND_END=              # Do Not Disturb loppu (HH:MM), ei pakollinen

# === Battery & WiFi Optimizer ===
# Pysäyttää tunnistuksen automaattisesti akun/WiFi:n perusteella
# PAUSE_ON_BATTERY=false             # true = pysäytä kun irti laturista
# HOME_SSIDS=Koti,Mökki              # kotiverkkojen SSID:t pilkuilla
# PAUSE_WHEN_AWAY=false              # true = pysäytä kun ei kotiverkossa

# === Web UI ===
# WEB_UI_PORT=8765
# WEB_UI_HOST=127.0.0.1
