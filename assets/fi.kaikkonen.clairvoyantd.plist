<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>fi.kaikkonen.clairvoyantd</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/Clairvoyant-Optics.app/Contents/MacOS/python</string>
        <string>/Applications/Clairvoyant-Optics.app/Contents/Resources/lib/python3.11/src/service/daemon.py</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/petekaik/.clairvoyant-optics/daemon-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/petekaik/.clairvoyant-optics/daemon-stderr.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
